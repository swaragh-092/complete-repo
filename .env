# ══════════════════════════════════════════════════════════════════════════════
# SSO Stack — Root Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Values marked CHANGE_ME are weak/unset — replace before going live.
# Generate secrets with:  openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════════════════


# ─── General ──────────────────────────────────────────────────────────────────
NODE_ENV=production


# ══════════════════════════════════════════════════════════════════════════════
# DATABASES
# ══════════════════════════════════════════════════════════════════════════════

# ─── Auth Service DB (postgres-auth) ──────────────────────────────────────────
AUTH_DB_NAME=authzotion_db
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=CHANGE_ME

# ─── PMS DB (db-pms) + Super-Admin DB (db-super-admin) ───────────────────────
PMS_DB_USER=postgres
PMS_DB_PASSWORD=CHANGE_ME

# ─── Email Service DB (db-email) ──────────────────────────────────────────────
EMAIL_DB_PASSWORD=CHANGE_ME


# ══════════════════════════════════════════════════════════════════════════════
# KEYCLOAK
# ══════════════════════════════════════════════════════════════════════════════

# Internal Docker URL — backend services call Keycloak through nginx so KC_HOSTNAME matches
# NODE_TLS_REJECT_UNAUTHORIZED=0 is set in docker-compose.yml to skip cert validation
KEYCLOAK_URL=https://keycloak.gururajhr.in

# Public-facing URL — for token issuer validation in browsers / OIDC redirects
FRONTEND_AUTH_URL=https://keycloak.gururajhr.in

KEYCLOAK_REALM=my-projects
KEYCLOAK_REALM_ID=

# Client secret for the account-ui Keycloak client
KEYCLOAK_ACCOUNT_UI_CLIENT_SECRET=xIOG249tgLkO8M6DIzKRjFVCsoRHYNDl


# ══════════════════════════════════════════════════════════════════════════════
# AUTH SERVICE
# ══════════════════════════════════════════════════════════════════════════════

AUTH_SERVICE_PORT=4000

# Public-facing URLs (used by auth-service when generating links / cookies)
FRONTEND_URL=https://admin.gururajhr.in
ACCOUNT_UI_URL=https://account.gururajhr.in
AUTH_SERVICE_URL=https://auth.gururajhr.in

# Keycloak service-account credentials for auth-service
AUTH_SERVICE_CLIENT_ID=auth-service
AUTH_SERVICE_CLIENT_SECRET=bW2g5UdXlwTeoJ832s9QkaIb1iyrMSxW

# Session — must be a strong random string (min 32 chars)
SESSION_SECRET=CHANGE_ME
SESSION_COOKIE_NAME=auth.sid
SESSION_COOKIE_DOMAIN=.gururajhr.in
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=none

# Refresh token cookie
REFRESH_COOKIE_DOMAIN=.gururajhr.in
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=none
REFRESH_COOKIE_MAX_AGE=2592000

# Proxy / CORS
TRUST_PROXY=true
CORS_FALLBACK_ORIGINS=https://admin.gururajhr.in,https://account.gururajhr.in,https://pms.gururajhr.in,https://org.gururajhr.in

# Device fingerprinting
FP_SALT=CHANGE_ME
DEVICE_TRUST_DURATION_DAYS=30
DEVICE_MAX_PER_USER=10
DEVICE_SIMILARITY_THRESHOLD=85


# ══════════════════════════════════════════════════════════════════════════════
# SERVICE-TO-SERVICE SHARED SECRET
# ══════════════════════════════════════════════════════════════════════════════
# Shared between auth-service and email-service for internal API calls.
SERVICE_SECRET=7f32af7f747bfd98b5e175de321f04ac8f387e7dba9e26b19654442b1c2f0abd


# ══════════════════════════════════════════════════════════════════════════════
# EMAIL SERVICE
# ══════════════════════════════════════════════════════════════════════════════

EMAIL_SERVICE_PORT=4011

# ─── Primary SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=swaragh82@gmail.com
SMTP_PASS=aqxtriojfqultloy
FROM_EMAIL=swaragh82@gmail.com

# ─── Backup SMTP (optional failover) ──────────────────────────────────────────
SMTP_BACKUP_HOST=
SMTP_BACKUP_PORT=587
SMTP_BACKUP_USER=
SMTP_BACKUP_PASS=

# ─── Email service settings ───────────────────────────────────────────────────
APP_NAME=SSO Platform
POOL=true
MAXCONNECTIONS=5
MAXMESSAGES=100
QUEUE_MAX_ATTEMPTS=3
LOG_RETENTION_DAYS=90
MAX_DELAY_MS=604800000
CLIENT_CACHE_TTL_MS=6000000

# Keycloak client credentials for email-service
EMAIL_SERVICE_CLIENT_ID=email-service
EMAIL_SERVICE_CLIENT_SECRET=CHANGE_ME
EMAIL_KEYCLOAK_URL=https://keycloak.gururajhr.in


# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND BUILD ARGS — Auth UI (admin dashboard SPA)
# ══════════════════════════════════════════════════════════════════════════════
VITE_AUTH_UI_CLIENT_KEY=admin-ui
VITE_AUTH_UI_AUTH_BASE_URL=https://auth.gururajhr.in
VITE_AUTH_UI_API_URL=https://auth.gururajhr.in
VITE_AUTH_UI_AUTH_URL=https://keycloak.gururajhr.in
VITE_AUTH_UI_CALLBACK_URL=https://admin.gururajhr.in/callback


# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND BUILD ARGS — Centralized Login (user login portal SPA)
# ══════════════════════════════════════════════════════════════════════════════
VITE_LOGIN_CLIENT_KEY=account-ui
VITE_LOGIN_AUTH_BASE_URL=https://auth.gururajhr.in/auth
VITE_LOGIN_ACCOUNT_UI_URL=https://account.gururajhr.in
VITE_LOGIN_REDIRECT_URI=https://account.gururajhr.in/callback


# ══════════════════════════════════════════════════════════════════════════════
# PMS v2
# ══════════════════════════════════════════════════════════════════════════════
PMS_SERVICE_CLIENT_SECRET=VBEIFnak29KKCr7vWS03pEtJDdp973PB

# PMS Frontend SSO client — must match keycloak-setup/02-fn-pms-client.sql (v_secret)
# and auth-service/migrations/20260407000000-add-fn-pms-client.js (FN_PMS_SECRET)
FN_PMS_CLIENT_SECRET=75a9a6882aef7a1d149086c88cf57d63cd4ddc01f591816efd50e3af1f10bbdd


# ══════════════════════════════════════════════════════════════════════════════
# SUPER ADMINISTRATOR SERVICE
# ══════════════════════════════════════════════════════════════════════════════

ENV=production
DB_PREFIX=

# AES encryption
# IMPORTANT: ENC_IV must be exactly 16 hex characters (32 hex chars = 16 bytes)
ENC_KEY=4bc12f3e7189a4f25bcd76e8a9d1c2f3
ENC_IV=1a2b3c4d5e6f0000

# JWT secrets — replace HelloWorld@123 with strong secrets before going live
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# Token expiry — values are parsed by the service (no inline comments allowed here)
ACCESS_TOKEN_EXPIRE_TIME=15m
REFRESH_TOKEN_EXPIRE_TIME=30d
RESET_PASSWORD_TOKEN_EXPIRE_TIME=1h

FRONT_END_DOMAIN=https://admin.gururajhr.in



