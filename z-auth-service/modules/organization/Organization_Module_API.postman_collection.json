{
    "info": {
        "name": "Organization Module API",
        "description": "Complete Postman collection for the Organization Module — covers Organizations, Onboarding, Memberships, and Workspaces APIs.\n\nAll routes require a valid Bearer Token.\n\nBase URL variable: {{baseUrl}} (default: http://localhost:4000/api)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{accessToken}}",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:4000/api"
        },
        {
            "key": "accessToken",
            "value": ""
        },
        {
            "key": "orgId",
            "value": ""
        },
        {
            "key": "membershipId",
            "value": ""
        },
        {
            "key": "workspaceId",
            "value": ""
        },
        {
            "key": "userId",
            "value": ""
        },
        {
            "key": "invitationId",
            "value": ""
        },
        {
            "key": "roleId",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "🏢 Organizations",
            "item": [
                {
                    "name": "List All Organizations",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organizations?tenant_id=",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations"
                            ],
                            "query": [
                                {
                                    "key": "tenant_id",
                                    "value": "",
                                    "description": "Optional tenant filter"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Organization by ID",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Create Organization",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/organizations",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"My Organization\",\n  \"tenant_id\": \"my-org-slug\",\n  \"description\": \"Optional description\"\n}"
                        }
                    }
                },
                {
                    "name": "Update Organization",
                    "request": {
                        "method": "PUT",
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Updated Organization Name\",\n  \"description\": \"Updated description\"\n}"
                        }
                    }
                },
                {
                    "name": "Delete Organization",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Organization Members",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}/members",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}",
                                "members"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Organization Stats Overview",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organizations/stats/overview",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "stats",
                                "overview"
                            ]
                        }
                    }
                },
                {
                    "name": "My Organizations",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organizations/my/organizations",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "my",
                                "organizations"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "🚀 Onboarding",
            "item": [
                {
                    "name": "Create Organization (Self-Service)",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/org-onboarding/create",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "org-onboarding",
                                "create"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Acme Corp\",\n  \"client_key\": \"account-ui\",\n  \"description\": \"Our new organization\",\n  \"settings\": {}\n}"
                        }
                    }
                },
                {
                    "name": "Join Organization (Invitation Code)",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/org-onboarding/join",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "org-onboarding",
                                "join"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"invitation_code\": \"paste-invitation-code-here\"\n}"
                        }
                    }
                },
                {
                    "name": "Accept Pending Invitation",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/org-onboarding/accept-pending",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "org-onboarding",
                                "accept-pending"
                            ]
                        }
                    }
                },
                {
                    "name": "List Pending Invitations",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/org-onboarding/invitations?org_id={{orgId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "org-onboarding",
                                "invitations"
                            ],
                            "query": [
                                {
                                    "key": "org_id",
                                    "value": "{{orgId}}",
                                    "description": "Required: Organization ID"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Send Invitation",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/org-onboarding/invitations",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "org-onboarding",
                                "invitations"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"org_id\": \"{{orgId}}\",\n  \"invited_email\": \"colleague@example.com\",\n  \"role_id\": \"{{roleId}}\",\n  \"expires_in_days\": 7,\n  \"message\": \"Welcome to the team!\"\n}"
                        }
                    }
                },
                {
                    "name": "Revoke Invitation",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/org-onboarding/invitations/{{invitationId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "org-onboarding",
                                "invitations",
                                "{{invitationId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Admin Provision Organization",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/org-onboarding/admin/provision",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "org-onboarding",
                                "admin",
                                "provision"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"org_name\": \"Client Corp\",\n  \"owner_email\": \"owner@clientcorp.com\",\n  \"description\": \"Provisioned by admin\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "👥 Memberships",
            "item": [
                {
                    "name": "List All Memberships",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organization-memberships",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organization-memberships"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Membership by ID",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organization-memberships/{{membershipId}}",
