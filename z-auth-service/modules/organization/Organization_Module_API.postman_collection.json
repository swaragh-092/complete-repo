                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organization-memberships",
                                "{{membershipId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Create Membership",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/organization-memberships",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organization-memberships"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"org_id\": \"{{orgId}}\",\n  \"role_id\": \"{{roleId}}\"\n}"
                        }
                    }
                },
                {
                    "name": "Update Membership Role",
                    "request": {
                        "method": "PUT",
                        "url": {
                            "raw": "{{baseUrl}}/organization-memberships/{{membershipId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organization-memberships",
                                "{{membershipId}}"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"role_id\": \"{{roleId}}\"\n}"
                        }
                    }
                },
                {
                    "name": "Delete Membership",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/organization-memberships/{{membershipId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organization-memberships",
                                "{{membershipId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Bulk Assign Memberships",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/organization-memberships/bulk-assign",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organization-memberships",
                                "bulk-assign"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"org_id\": \"{{orgId}}\",\n  \"role_id\": \"{{roleId}}\",\n  \"user_ids\": [\n    \"user-uuid-1\",\n    \"user-uuid-2\"\n  ]\n}"
                        }
                    }
                },
                {
                    "name": "Get Memberships by User",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organization-memberships/user/{{userId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organization-memberships",
                                "user",
                                "{{userId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Membership Stats",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organization-memberships/stats/overview",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organization-memberships",
                                "stats",
                                "overview"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "🗂️ Workspaces",
            "item": [
                {
                    "name": "List Workspaces",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces?org_id={{orgId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces"
                            ],
                            "query": [
                                {
                                    "key": "org_id",
                                    "value": "{{orgId}}",
                                    "description": "Optional org filter"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Create Workspace",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"org_id\": \"{{orgId}}\",\n  \"name\": \"Engineering Team\",\n  \"slug\": \"engineering\",\n  \"description\": \"Engineering workspace\"\n}"
                        }
                    }
                },
                {
                    "name": "Get Workspace by ID",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces/{{workspaceId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces",
                                "{{workspaceId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Workspace",
                    "request": {
                        "method": "PUT",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces/{{workspaceId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces",
                                "{{workspaceId}}"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Updated Workspace Name\",\n  \"description\": \"Updated description\"\n}"
                        }
                    }
                },
                {
                    "name": "Delete Workspace",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces/{{workspaceId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces",
                                "{{workspaceId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "List Workspace Members",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces",
                                "{{workspaceId}}",
                                "members"
                            ]
                        }
                    }
                },
                {
                    "name": "Add Member to Workspace",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces",
                                "{{workspaceId}}",
                                "members"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"role\": \"editor\"\n}"
                        }
                    }
                },
                {
                    "name": "Update Workspace Member Role",
                    "request": {
                        "method": "PUT",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members/{{userId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces",
                                "{{workspaceId}}",
                                "members",
                                "{{userId}}"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"role\": \"admin\"\n}"
                        }
                    }
                },
                {
                    "name": "Remove Member from Workspace",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members/{{userId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces",
                                "{{workspaceId}}",
                                "members",
                                "{{userId}}"
                            ]
                        }
                    }
