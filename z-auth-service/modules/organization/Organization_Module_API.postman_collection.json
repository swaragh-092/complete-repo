                {
                    "name": "Preview Workspace Invitation",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/workspaces/invitations/preview?code=invitation-code-here",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "workspaces",
                                "invitations",
                                "preview"
                            ],
                            "query": [
                                {
                                    "key": "code",
                                    "value": "invitation-code-here",
                                    "description": "Invitation code to preview"
